//+------------------------------------------------------------------+\n//|                                                    XAUUSD_Backcom_Advanced.mq4 |\n//|                        Expert Advisor for Metatrader 4         |\n//|                                      Author: vothidiemhuong2025-debug |\n//|                                              Date: 2026-03-16 |\n//+------------------------------------------------------------------+\n\n// Input parameters\ninput double capital = 10; // Initial capital in USD\ninput double lotSize = 0.01; // Micro lot size\ninput double stopLoss = 10; // Tight stop loss in pips\ninput int maxTrades = 100; // Maximum number of trades\n\n// Global variables\ndouble backcomRebate; // Variable to store rebate amount\nint totalTrades = 0; // Counter for total trades executed\n\n//+------------------------------------------------------------------+\n//|                  Expert initialization function                     |\n//+------------------------------------------------------------------+\nint OnInit() {\n    backcomRebate = 0;\n    return INIT_SUCCEEDED;\n}\n\n//+------------------------------------------------------------------+\n//|                  Expert deinitialization function                   |\n//+------------------------------------------------------------------+\nvoid OnDeinit(const int reason) {\n    Print("Total Backcom Rebate: ", backcomRebate);\n}\n\n//+------------------------------------------------------------------+\n//|                  Expert tick function                                |\n//+------------------------------------------------------------------+\nvoid OnTick() {\n    if (totalTrades < maxTrades) {\n        // Open Buy Order\n        double price = Ask;\n        double sl = price - stopLoss * Point;\n        double lot = lotSize;\n        int ticket = OrderSend(Symbol(), OP_BUY, lot, price, 3, sl, 0, "Backcom EA", 0, 0, clrGreen);\n        if (ticket > 0) {\n            totalTrades++;\n            // Update rebate amount for each order opened\n            backcomRebate += lotSize * 1; // Example: fixed rebate rate\n        }\n    }\n}\n//+------------------------------------------------------------------+\n